<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <!-- android 11 文件管理权限-->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- 联网权限，Webview加载需要 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 监听通知 -->
    <uses-permission
        android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions" />
    <permission
        android:name="android.permission.GET_INTENT_SENDER_INTENT"
        android:protectionLevel="signature"
        tools:ignore="ReservedSystemPermission" />

    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- 获取应用信息 -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.GET_PACKAGE_SIZE" />

    <!-- 获取通知 -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission
        android:name="android.permission.GET_INTENT_SENDER_INTENT"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!--    <uses-permission android:name="android.permission.READ_PHONE_STATE" />-->

    <uses-permission
        android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!--    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />-->

    <uses-permission android:name="android.permission.MEDIA_CONTENT_CONTROL" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.app.role.DIALER" />


    <application
        android:allowBackup="true"
        android:extractNativeLibs="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/ActivityMain">
        <activity
            android:name=".MainActivity"
            android:alwaysRetainTaskState="true"
            android:configChanges="locale|keyboardHidden|navigation|orientation|uiMode|screenSize|fontScale|screenLayout|smallestScreenSize|density"
            android:exported="true"
            android:hardwareAccelerated="false"
            android:label="@string/app_name"
            android:launchMode="standard"
            android:resizeableActivity="false"
            android:screenOrientation="portrait"
            android:theme="@style/ActivityMain"
            android:windowSoftInputMode="adjustPan|stateAlwaysHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".pages.whatsapp.AllStatusActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.AllStatusActivity"
            android:theme="@style/ActivityMain"></activity>

        <activity
            android:name=".pages.whatsapp.WhatsAppCacheActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.WhatsAppCacheActivity"
            android:theme="@style/ActivityMain">

            <intent-filter>
                <action android:name="com.example.action.APP_ACTION" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

        </activity>

        <provider
            android:name="com.onus.demotest.data.ShareFileProvider"
            android:authorities="${applicationId}.sharefileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/sharefilepaths" />
        </provider>

        <activity
            android:name=".pages.webview.WebViewActivity"
            android:alwaysRetainTaskState="true"
            android:configChanges="locale|keyboardHidden|navigation|orientation|uiMode|screenSize|fontScale|screenLayout|smallestScreenSize|density"
            android:excludeFromRecents="true"
            android:exported="false"
            android:hardwareAccelerated="false"
            android:label="@string/app_name"
            android:launchMode="standard"
            android:resizeableActivity="false"
            android:screenOrientation="portrait"
            android:taskAffinity="com.onus.demotest.pages.WebViewActivity"
            android:theme="@style/Theme.DemoTest"
            android:windowSoftInputMode="adjustPan|stateAlwaysHidden" />

        <activity
            android:name=".pages.notification.BindNotificationActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.BindNotificationActivity"
            android:theme="@style/ActivityMain" />

        <service
            android:name=".services.PushMonitorService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <activity
            android:name=".pages.notification.NotifyDemoActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.NotifyDemoActivity"
            android:theme="@style/ActivityMain"></activity>

        <activity
            android:name=".pages.notification.IncomingCallActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.IncomingCallActivity"
            android:theme="@style/ActivityMain"></activity>

        <service
            android:name=".pages.notification.CallNotificationService"
            android:foregroundServiceType="phoneCall"
            android:exported="false" />

        <receiver
            android:name=".pages.notification.NotificationBroadcastReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="PLAY_ACTION" />
                <action android:name="PREV_ACTION" />
                <action android:name="NEXT_ACTION" />
                <action android:name="REPLY_ACTION" />
                <action android:name="CALL_ACCEPT" />
                <action android:name="CALL_REJECT" />
            </intent-filter>
        </receiver>

        <service
            android:name=".pages.notification.MediaPlaybackServiceCompat"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback" >
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </service>


        <!--        <receiver-->
        <!--            android:name="androidx.media.session.MediaButtonReceiver"-->
        <!--            android:exported="true">-->
        <!--            <intent-filter>-->
        <!--                <action android:name="android.intent.action.MEDIA_BUTTON" />-->
        <!--            </intent-filter>-->
        <!--        </receiver>-->

        <activity
            android:name=".pages.file.AllFileActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.AllFileActivity"
            android:theme="@style/ActivityMain"></activity>

        <activity
            android:name=".pages.file.UsageStatsActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.UsageStatsActivity"
            android:theme="@style/ActivityMain">
            <intent-filter>
                <action android:name="android.os.storage.action.MANAGE_STORAGE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".pages.video.VideoActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.VideoActivity"
            android:theme="@style/ActivityMain" />

        <activity
            android:name=".pages.ui.tab.TabActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.demo.TabActivity"
            android:theme="@style/ActivityMain" />

        <activity
            android:name=".pages.ui.FontsActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.FontsActivity"
            android:theme="@style/ActivityMain" />

        <activity
            android:name=".pages.ui.FrameActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.FrameActivity"
            android:theme="@style/ActivityMain" />

        <activity
            android:name=".pages.ui.DialogActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.DialogActivity"
            android:theme="@style/ActivityMain" />

        <activity
            android:name=".pages.notification.PostNotificationActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.PostNotificationActivity"
            android:theme="@style/ActivityMain" />

        <activity
            android:name=".pages.ui.draglist.DragListActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="standard"
            android:taskAffinity="com.onus.demotest.pages.demo.DragListActivity"
            android:theme="@style/ActivityMain" />

        <service
            android:name="com.google.firebase.messaging.FirebaseMessagingService"
            android:directBootAware="true"
            android:exported="false"
            android:process=":service">

            <intent-filter android:priority="-500">

                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <service
            android:name=".fcm.FcmMessageService"
            android:directBootAware="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <provider
            android:name="com.onus.demotest.services.IPCServiceProvider"
            android:authorities="${applicationId}.pigeon.service"
            android:exported="false"
            android:process=":service" />

        <activity
            android:name=".test.UriReceiveActivity"
            android:exported="true"
            android:theme="@style/ActivityMain">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
                <data android:scheme="content" />
            </intent-filter>
        </activity>
    </application>

</manifest>
